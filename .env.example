# ── GR Scale Website — Environment Variables ──
# Copy this file to .env.local for local dev, and add the same keys in
# Vercel → Project → Settings → Environment Variables for production.

# REQUIRED for the contact + book forms to work.
# Get a free form ID at https://formspree.io (looks like "xayzwabc").
NEXT_PUBLIC_FORMSPREE_ID=

# Your live site URL (used for SEO/canonical links). No trailing slash.
NEXT_PUBLIC_SITE_URL=https://grscale.com
